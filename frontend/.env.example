# Copy to .env and fill in values.

REACT_APP_AUTH0_DOMAIN=your-tenant.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your-client-id

# Optional for local dev: omit to use CRA proxy → http://localhost:3000
# Production: set in .env.production or host env (e.g. Render API URL)
# REACT_APP_API_URL=https://cosplay-collabs.onrender.com
