# --- Neon (recommended for production) ---
# Copy your connection string from Neon: Dashboard → Connection details
# Must include SSL, e.g. ...?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# --- Local Postgres (only if DATABASE_URL is NOT set) ---
# DB_USER=postgres
# DB_HOST=localhost
# DB_DATABASE=your_db_name
# DB_PASSWORD=your_password
# DB_PORT=5432
